# OPAS PoC — environment variables (TEMPLATE, safe to commit)
# Copy this file to `.env` and fill in values from the Supabase dashboard.
# NEVER commit `.env` to git. `.env` must be in `.gitignore`.

# --- Supabase ---------------------------------------------------------------
# Dashboard → Project Settings → API (and API Keys)
# Note: Supabase renamed its keys in late 2025. UI labels vs env-var names:
#   UI "Publishable key" (sb_publishable_...)  →  SUPABASE_ANON_KEY
#   UI "Secret key"      (sb_secret_...)       →  SUPABASE_SERVICE_ROLE_KEY
# Either JWT-style or sb_ prefix values work with the current client libraries.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# --- LLM providers (server-side only; never shipped to browser) -------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Optional ---------------------------------------------------------------
ELEVENLABS_API_KEY=          # voice tutoring — stretch goal, not PoC commitment
MEM0_API_KEY=                # if using Mem0's hosted service; empty = self-hosted
